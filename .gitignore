# Python caches / build
__pycache__/
*.py[cod]
*.egg-info/

# Virtual environments
.venv/
venv/
env/

# PyInstaller / cx_Freeze build output + scratch
/build/
/dist/
/.pyibuild/
/.iscc_path
*.manifest
*.log

# Runtime output — keep the folders (.gitkeep), ignore their contents
logs/*
screenshots/*
reports/*
!logs/.gitkeep
!screenshots/.gitkeep
!reports/.gitkeep
